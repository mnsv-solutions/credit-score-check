generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model genders {
  gender_id   String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gender_code String     @unique @db.VarChar(20)
  gender_name String     @unique @db.VarChar(50)
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  created_by  String?    @db.Uuid
  updated_at  DateTime   @default(now()) @db.Timestamptz(6)
  updated_by  String?    @db.Uuid
  is_active   Boolean    @default(true)
  customers   customer[]
}

model marital_statuses {
  marital_status_id   String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  marital_status_code String     @unique @db.VarChar(20)
  marital_status_name String     @unique @db.VarChar(50)
  created_at          DateTime   @default(now()) @db.Timestamptz(6)
  created_by          String?    @db.Uuid
  updated_at          DateTime   @default(now()) @db.Timestamptz(6)
  updated_by          String?    @db.Uuid
  is_active           Boolean    @default(true)
  customers           customer[]
}

model countries {
  country_id       String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  country_code     String                     @unique @db.VarChar(3)
  country_name     String                     @unique @db.VarChar(100)
  nationality_name String                     @unique @db.VarChar(100)
  created_at       DateTime                   @default(now()) @db.Timestamptz(6)
  created_by       String?                    @db.Uuid
  updated_at       DateTime                   @default(now()) @db.Timestamptz(6)
  updated_by       String?                    @db.Uuid
  is_active        Boolean                    @default(true)
  customer_address customer_address_details[]
  customers        customer[]                 @relation("customer_nationality")
}

model government_id_types {
  government_id_type_id   String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  government_id_type_code String                   @unique @db.VarChar(30)
  government_id_type_name String                   @unique @db.VarChar(80)
  created_at              DateTime                 @default(now()) @db.Timestamptz(6)
  created_by              String?                  @db.Uuid
  updated_at              DateTime                 @default(now()) @db.Timestamptz(6)
  updated_by              String?                  @db.Uuid
  is_active               Boolean                  @default(true)
  customer_ids            customer_government_id[]
}

model contact_types {
  contact_type_id   String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contact_type_code String                     @unique @db.VarChar(30)
  contact_type_name String                     @unique @db.VarChar(80)
  created_at        DateTime                   @default(now()) @db.Timestamptz(6)
  created_by        String?                    @db.Uuid
  updated_at        DateTime                   @default(now()) @db.Timestamptz(6)
  updated_by        String?                    @db.Uuid
  is_active         Boolean                    @default(true)
  contact_details   customer_contact_details[]
}

model income_source_types {
  income_source_type_id   String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  income_source_type_code String                    @unique @db.VarChar(30)
  income_source_type_name String                    @unique @db.VarChar(80)
  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  created_by              String?                   @db.Uuid
  updated_at              DateTime                  @default(now()) @db.Timestamptz(6)
  updated_by              String?                   @db.Uuid
  is_active               Boolean                   @default(true)
  income_sources          customer_income_sources[]
}

model liability_types {
  liability_type_id   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  liability_type_code String                 @unique @db.VarChar(30)
  liability_type_name String                 @unique @db.VarChar(80)
  created_at          DateTime               @default(now()) @db.Timestamptz(6)
  created_by          String?                @db.Uuid
  updated_at          DateTime               @default(now()) @db.Timestamptz(6)
  updated_by          String?                @db.Uuid
  is_active           Boolean                @default(true)
  liabilities         customer_liabilities[]
}

model bank_account_types {
  bank_account_type_id String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_type_code    String                  @unique @db.VarChar(20)
  account_type_name    String                  @unique @db.VarChar(50)
  created_at           DateTime                @default(now()) @db.Timestamptz(6)
  created_by           String?                 @db.Uuid
  updated_at           DateTime                @default(now()) @db.Timestamptz(6)
  updated_by           String?                 @db.Uuid
  is_active            Boolean                 @default(true)
  bank_details         customer_bank_details[]
}

model document_types {
  document_type_id   String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  document_type_code String                      @unique @db.VarChar(30)
  document_type_name String                      @unique @db.VarChar(80)
  created_at         DateTime                    @default(now()) @db.Timestamptz(6)
  created_by         String?                     @db.Uuid
  updated_at         DateTime                    @default(now()) @db.Timestamptz(6)
  updated_by         String?                     @db.Uuid
  is_active          Boolean                     @default(true)
  documents          customer_document_details[]
}

