/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model address_types {
  address_type_id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  address_type_code                     String   @db.VarChar(30)
  address_type_name                     String   @db.VarChar(80)
  created_at                            DateTime @default(now()) @db.Timestamptz(6)
  created_by                            String?  @db.Uuid
  updated_at                            DateTime @default(now()) @db.Timestamptz(6)
  updated_by                            String?  @db.Uuid
  is_active                             Boolean  @default(true)
  users_address_types_created_byTousers users?   @relation("address_types_created_byTousers", fields: [created_by], references: [user_id], onUpdate: NoAction, map: "fk_address_types_created_by")
  users_address_types_updated_byTousers users?   @relation("address_types_updated_byTousers", fields: [updated_by], references: [user_id], onUpdate: NoAction, map: "fk_address_types_updated_by")

  @@index([is_active], map: "idx_address_types_is_active")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model application_status {
  status_id                                  String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status_code                                String                       @db.VarChar(30)
  status_name                                String                       @db.VarChar(80)
  created_at                                 DateTime                     @default(now()) @db.Timestamptz(6)
  created_by                                 String?                      @db.Uuid
  updated_at                                 DateTime                     @default(now()) @db.Timestamptz(6)
  updated_by                                 String?                      @db.Uuid
  is_active                                  Boolean                      @default(true)
  users_application_status_created_byTousers users?                       @relation("application_status_created_byTousers", fields: [created_by], references: [user_id], onUpdate: NoAction, map: "fk_application_status_created_by")
  users_application_status_updated_byTousers users?                       @relation("application_status_updated_byTousers", fields: [updated_by], references: [user_id], onUpdate: NoAction, map: "fk_application_status_updated_by")
  loan_application                           loan_application[]
  application_action_history_from            application_action_history[] @relation("application_action_history_from_status")
  application_action_history_to              application_action_history[] @relation("application_action_history_to_status")

  @@index([is_active], map: "idx_application_status_is_active")
}

model application_status_audit {
  audit_id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_number String   @db.VarChar(40)
  dob_hash           String   @db.VarChar(128)
  success            Boolean  @default(false)
  reason_code        String   @default("UNKNOWN") @db.VarChar(30)
  ip_address         String?  @db.VarChar(80)
  user_agent         String?  @db.VarChar(255)
  created_at         DateTime @default(now()) @db.Timestamptz(6)

  @@index([application_number], map: "idx_status_audit_app_number")
  @@index([created_at(sort: Desc)], map: "idx_status_audit_created_at")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model banks {
  bank_id                       String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bank_code                     String                  @db.VarChar(30)
  bank_name                     String                  @db.VarChar(120)
  created_at                    DateTime                @default(now()) @db.Timestamptz(6)
  created_by                    String?                 @db.Uuid
  updated_at                    DateTime                @default(now()) @db.Timestamptz(6)
  updated_by                    String?                 @db.Uuid
  is_active                     Boolean                 @default(true)
  users_banks_created_byTousers users?                  @relation("banks_created_byTousers", fields: [created_by], references: [user_id], onUpdate: NoAction, map: "fk_banks_created_by")
  users_banks_updated_byTousers users?                  @relation("banks_updated_byTousers", fields: [updated_by], references: [user_id], onUpdate: NoAction, map: "fk_banks_updated_by")
  customer_banking              customer_bank_details[]

  @@index([is_active], map: "idx_banks_is_active")
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.

model cibil_reports {
  cibil_report_id           String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_id            String                      @unique(map: "uq_cibil_reports_application_id") @db.Uuid
  request_id                String                      @unique(map: "uq_cibil_reports_request_id") @db.VarChar(50)
  reference_id              String                      @unique(map: "uq_cibil_reports_reference_id") @db.VarChar(50)
  bureau                    String                      @default("CIBIL") @db.VarChar(20)
  report_date               DateTime                    @db.Timestamptz(6)
  status                    String                      @db.VarChar(20)
  cibil_score               Int
  score_band                String                      @db.VarChar(20)
  risk_level                String                      @db.VarChar(20)
  score_version             String                      @db.VarChar(20)
  total_accounts            Int
  active_accounts           Int
  closed_accounts           Int
  total_outstanding_balance Decimal                     @db.Decimal(14, 2)
  secured_loan_accounts     Int
  unsecured_loan_accounts   Int
  total_missed_payments     Int                         @default(0)
  recent_delinquency        Boolean                     @default(false)
  credit_utilization_ratio  Decimal                     @db.Decimal(5, 2)
  average_account_age_years Decimal                     @db.Decimal(5, 2)
  debt_to_income_estimate   Decimal                     @db.Decimal(5, 2)
  created_at                DateTime                    @default(now()) @db.Timestamptz(6)
  cibil_applicants          cibil_applicants?
  cibil_accounts            cibil_accounts[]
  cibil_enquiries           cibil_enquiries[]
  cibil_payment_history     cibil_payment_history[]
  cibil_risk_indicators     cibil_risk_indicators?
  application_credit_check  application_credit_check[]
  loan_application          loan_application            @relation(fields: [application_id], references: [application_id], onDelete: Cascade, onUpdate: NoAction)
  application_ratio_summary application_ratio_summary[]

  @@index([report_date], map: "idx_cibil_reports_report_date")
  @@index([cibil_score], map: "idx_cibil_reports_cibil_score")
  @@index([risk_level], map: "idx_cibil_reports_risk_level")
}

model cibil_applicants {
  cibil_applicant_id String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cibil_report_id    String        @unique(map: "uq_cibil_applicants_report_id") @db.Uuid
  first_name         String        @db.VarChar(100)
  last_name          String        @db.VarChar(100)
  date_of_birth      DateTime      @db.Date
  sin_number         String        @db.VarChar(20)
  mobile_number      String        @db.VarChar(15)
  cibil_reports      cibil_reports @relation(fields: [cibil_report_id], references: [cibil_report_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([sin_number], map: "idx_cibil_applicants_sin_number")
  @@index([mobile_number], map: "idx_cibil_applicants_mobile_number")
  @@index([date_of_birth], map: "idx_cibil_applicants_date_of_birth")
}

model cibil_accounts {
  cibil_account_id      String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cibil_report_id       String        @db.Uuid
  account_type          String        @db.VarChar(50)
  lender_name           String        @db.VarChar(100)
  account_number_masked String        @db.VarChar(20)
  ownership_type        String        @db.VarChar(50)
  open_date             DateTime      @db.Date
  current_balance       Decimal       @db.Decimal(14, 2)
  credit_limit          Decimal?      @db.Decimal(14, 2)
  payment_status        String        @db.VarChar(20)
  days_past_due         Int           @default(0)
  cibil_reports         cibil_reports @relation(fields: [cibil_report_id], references: [cibil_report_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([cibil_report_id], map: "idx_cibil_accounts_report_id")
  @@index([lender_name], map: "idx_cibil_accounts_lender_name")
}

model cibil_payment_history {
  cibil_payment_history_id String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cibil_report_id          String        @db.Uuid
  month_index              Int
  status_code              String        @db.VarChar(10)
  cibil_reports            cibil_reports @relation(fields: [cibil_report_id], references: [cibil_report_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([cibil_report_id, month_index], map: "uq_cibil_payment_history_report_month")
  @@index([cibil_report_id], map: "idx_cibil_payment_history_report_id")
}

model cibil_enquiries {
  cibil_enquiry_id String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cibil_report_id  String        @db.Uuid
  enquiry_date     DateTime      @db.Date
  institution      String        @db.VarChar(100)
  enquiry_type     String        @db.VarChar(50)
  cibil_reports    cibil_reports @relation(fields: [cibil_report_id], references: [cibil_report_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([cibil_report_id, enquiry_date], map: "idx_cibil_enquiries_report_date")
}

model cibil_risk_indicators {
  cibil_risk_indicator_id String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cibil_report_id         String        @unique(map: "uq_cibil_risk_indicators_report_id") @db.Uuid
  high_credit_utilization Boolean       @default(false)
  recent_hard_enquiries   Boolean       @default(false)
  thin_file               Boolean       @default(false)
  credit_mix_healthy      Boolean       @default(true)
  cibil_reports           cibil_reports @relation(fields: [cibil_report_id], references: [cibil_report_id], onDelete: Cascade, onUpdate: NoAction)
}

model customer {
  customer_id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  first_name             String   @db.VarChar(80)
  last_name              String   @db.VarChar(80)
  date_of_birth          DateTime @db.Date
  gender_id              String?  @db.Uuid
  marital_status_id      String?  @db.Uuid
  nationality_country_id String?  @db.Uuid
  sin_tax_id_masked      String?  @db.VarChar(30)
  sin_tax_id_encrypted   Bytes?   @db.ByteA
  created_at             DateTime @default(now()) @db.Timestamptz(6)
  created_by             String   @db.Uuid
  updated_at             DateTime @default(now()) @db.Timestamptz(6)
  updated_by             String?  @db.Uuid
  is_active              Boolean  @default(true)

  // Relations
  gender                           genders?          @relation(fields: [gender_id], references: [gender_id], onUpdate: NoAction)
  marital_status                   marital_statuses? @relation(fields: [marital_status_id], references: [marital_status_id], onUpdate: NoAction)
  nationality                      countries?        @relation("customer_nationality", fields: [nationality_country_id], references: [country_id], onUpdate: NoAction)
  users_customer_created_byTousers users             @relation("customer_created_byTousers", fields: [created_by], references: [user_id], onUpdate: NoAction)
  users_customer_updated_byTousers users?            @relation("customer_updated_byTousers", fields: [updated_by], references: [user_id], onDelete: Restrict, onUpdate: NoAction)

  sub_loan           sub_loan[]
  contact_details    customer_contact_details[]
  address_details    customer_address_details[]
  education_details  customer_education_details[]
  employment_details customer_employment_details?
  income_sources     customer_income_sources[]
  liabilities        customer_liabilities[]
  government_ids     customer_government_id[]
  bank_details       customer_bank_details[]
  documents          customer_document_details[]

  application_ratio_summary application_ratio_summary[]

  @@index([is_active], map: "idx_customer_active")
  @@index([date_of_birth], map: "idx_customer_dob")
  @@index([gender_id], map: "idx_customer_gender")
  @@index([marital_status_id], map: "idx_customer_marital_status")
  @@index([nationality_country_id], map: "idx_customer_nationality_country")
}

model customer_contact_details {
  customer_contact_id String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id         String   @db.Uuid
  contact_type_id     String   @db.Uuid
  contact_value       String   @db.VarChar(255)
  is_primary          Boolean  @default(false)
  is_verified         Boolean  @default(false)
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  created_by          String?  @db.Uuid
  updated_at          DateTime @default(now()) @db.Timestamptz(6)
  updated_by          String?  @db.Uuid
  is_active           Boolean  @default(true)

  customer     customer      @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)
  contact_type contact_types @relation(fields: [contact_type_id], references: [contact_type_id])

  @@index([customer_id, is_active], map: "idx_customer_contact_customer_active")
}

model customer_address_details {
  customer_address_id String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id         String   @db.Uuid
  address_type_id     String   @db.Uuid
  line1               String   @db.VarChar(120)
  line2               String?  @db.VarChar(120)
  city                String   @db.VarChar(80)
  state_province      String?  @db.VarChar(80)
  postal_code         String?  @db.VarChar(20)
  country_id          String   @db.Uuid
  is_primary          Boolean  @default(false)
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  is_active           Boolean  @default(true)

  customer customer  @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)
  country  countries @relation(fields: [country_id], references: [country_id])

  @@index([customer_id, is_active], map: "idx_customer_address_customer_active")
}

model customer_employment_details {
  customer_employment_id String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id            String   @unique @db.Uuid
  employment_type_id     String   @db.Uuid
  employer_name          String?  @db.VarChar(150)
  job_title              String?  @db.VarChar(120)
  work_experience_years  Decimal? @db.Decimal(5, 2)
  monthly_income         Decimal? @db.Decimal(12, 2)
  is_active              Boolean  @default(true)

  customer        customer         @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)
  employment_type employment_types @relation(fields: [employment_type_id], references: [employment_type_id])
}

model customer_liabilities {
  customer_liability_id    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id              String   @db.Uuid
  liability_type_id        String   @db.Uuid
  lender_name              String?  @db.VarChar(150)
  account_reference_masked String?  @db.VarChar(60)
  monthly_payment          Decimal  @default(0) @db.Decimal(12, 2)
  outstanding_balance      Decimal? @db.Decimal(14, 2)
  is_active                Boolean  @default(true)

  customer       customer        @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)
  liability_type liability_types @relation(fields: [liability_type_id], references: [liability_type_id])

  @@index([customer_id, is_active], map: "idx_customer_liabilities_customer_active")
}

model customer_government_id {
  customer_government_id_id      String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id                    String  @db.Uuid
  government_id_type_id          String  @db.Uuid
  government_id_number_masked    String  @db.VarChar(80)
  government_id_number_encrypted Bytes   @db.ByteA
  is_primary                     Boolean @default(true)
  is_active                      Boolean @default(true)

  customer customer            @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)
  id_type  government_id_types @relation(fields: [government_id_type_id], references: [government_id_type_id])

  @@index([customer_id, is_active], map: "idx_customer_government_id_customer_active")
}

model customer_bank_details {
  customer_bank_detail_id  String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id              String  @db.Uuid
  bank_id                  String  @db.Uuid
  bank_account_type_id     String  @db.Uuid
  account_number_masked    String  @db.VarChar(40)
  account_number_encrypted Bytes?  @db.ByteA
  is_primary               Boolean @default(true)
  is_active                Boolean @default(true)

  customer     customer           @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)
  bank         banks              @relation(fields: [bank_id], references: [bank_id])
  account_type bank_account_types @relation(fields: [bank_account_type_id], references: [bank_account_type_id])

  @@index([customer_id, is_active], map: "idx_customer_bank_customer_active")
}

model customer_document_details {
  customer_document_id String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id          String  @db.Uuid
  document_type_id     String  @db.Uuid
  document_name        String  @db.VarChar(255)
  document_path        String  @db.VarChar(500)
  mime_type            String? @db.VarChar(100)
  file_size_bytes      BigInt?
  is_verified          Boolean @default(false)
  is_active            Boolean @default(true)

  customer      customer       @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)
  document_type document_types @relation(fields: [document_type_id], references: [document_type_id])

  @@index([customer_id, is_active], map: "idx_customer_document_customer_active")
}

model customer_education_details {
  customer_education_id String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id           String  @db.Uuid
  education_level_id    String  @db.Uuid
  institution_id        String? @db.Uuid
  field_of_study        String? @db.VarChar(150)
  graduation_year       Int?
  is_active             Boolean @default(true)

  customer        customer         @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)
  education_level education_levels @relation(fields: [education_level_id], references: [education_level_id])
  institution     institutions?    @relation(fields: [institution_id], references: [institution_id])

  @@index([customer_id, is_active], map: "idx_customer_education_customer_active")
